# Chrome Extension -- Build-time Environment Variables
#
# Variable names mirror the web app (src/lib/env-client.ts) so the same
# .env contract works on both surfaces. WXT forwards NEXT_PUBLIC_* into
# import.meta.env at build time via vite envPrefix.
#
# Copy this file to .env and fill in the values for local development.
# Never commit .env to source control.

# Contact email shown in the extension UI and error messages.
NEXT_PUBLIC_CONTACT_EMAIL=ebnezr.isaac@gmail.com

# Root domain used to construct web URLs (no trailing slash, no protocol).
NEXT_PUBLIC_ROOT_DOMAIN=llmconveyors.com

# BCP-47 locale tag used as the default language for the extension UI.
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Full base URL for the LLM Conveyors API (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=https://api.llmconveyors.com

# Full base URL for the LLM Conveyors web app (no trailing slash).
NEXT_PUBLIC_WEB_BASE_URL=https://llmconveyors.com
