# Chrome Extension -- Build-time Environment Variables
#
# Variable names mirror the web app (src/lib/env-client.ts) so the same
# .env contract works on both surfaces. WXT forwards NEXT_PUBLIC_* into
# import.meta.env at build time via vite envPrefix.
#
# Copy this file to .env and fill in the values for local development.
# Never commit .env to source control.

# Single-source profile switch for extension endpoints/auth domains.
# - prod: llmconveyors production defaults
# - local: localhost:3000 defaults for web/api/cookie/manifest host
# - staging: staging.llmconveyors.com defaults
NEXT_PUBLIC_EXT_PROFILE=prod

# Local profile safety switch.
# When NEXT_PUBLIC_EXT_PROFILE=local, local mode is only enabled if this is true.
# This prevents accidental localhost auth/API routing in regular usage.
# NEXT_PUBLIC_EXT_ALLOW_LOCAL_PROFILE=true

# Contact email shown in the extension UI and error messages.
NEXT_PUBLIC_CONTACT_EMAIL=ebnezr.isaac@gmail.com

# Root domain used to construct web URLs (no trailing slash, no protocol).
# Optional override. If omitted, value comes from NEXT_PUBLIC_EXT_PROFILE.
# NEXT_PUBLIC_ROOT_DOMAIN=llmconveyors.com

# BCP-47 locale tag used as the default language for the extension UI.
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Full base URL for the LLM Conveyors API (no trailing slash).
# Optional override. If omitted, value comes from NEXT_PUBLIC_EXT_PROFILE.
# NEXT_PUBLIC_API_BASE_URL=https://api.llmconveyors.com

# Full base URL for the LLM Conveyors web app (no trailing slash).
# Optional override. If omitted, value comes from NEXT_PUBLIC_EXT_PROFILE.
# NEXT_PUBLIC_WEB_BASE_URL=https://llmconveyors.com

# Cookie lookup origin used by chrome.cookies.get during AUTH_COOKIE_EXCHANGE.
# Optional override. Defaults to NEXT_PUBLIC_WEB_BASE_URL.
# NEXT_PUBLIC_EXT_AUTH_COOKIE_URL=https://llmconveyors.com

# Cookie domain suffix watched by chrome.cookies.onChanged.
# Optional override. Defaults to hostname(NEXT_PUBLIC_WEB_BASE_URL).
# NEXT_PUBLIC_EXT_AUTH_COOKIE_DOMAIN=llmconveyors.com

# Optional override for MV3 manifest host calculation.
# Defaults to hostname(NEXT_PUBLIC_WEB_BASE_URL).
# NEXT_PUBLIC_EXT_MANIFEST_HOST=llmconveyors.com

# Auth recovery strategy toggle.
# - coordinator: global single-flight + breaker/backoff (default)
# - legacy: direct cookie exchange path without breaker state
NEXT_PUBLIC_EXT_AUTH_RECOVERY_MODE=coordinator

# Host permission scope for MV3 manifest generation.
# - strict: llmconveyors + primary ATS domains (default)
# - broad: https://*/* (legacy compatibility)
NEXT_PUBLIC_EXT_HOST_SCOPE=strict

## --- Extension Config ---
# Set NEXT_PUBLIC_EXT_PROFILE=local for localhost debugging.
# Set NEXT_PUBLIC_EXT_PROFILE=staging for staging environment.
